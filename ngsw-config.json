{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": ["/favicon.ico", "/index.html", "/manifest.webmanifest", "/*.css", "/*.js"]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/assets/**"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "ecb-rates",
      "urls": ["https://data-api.ecb.europa.eu/service/data/EXR/*"],
      "cacheConfig": {
        "maxSize": 1,
        "maxAge": "1d",
        "strategy": "freshness",
        "timeout": "10s"
      }
    }
  ]
}
